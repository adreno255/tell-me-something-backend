    "description": "The backend API server for Tell Me Something which is an MVP that allows users to express their unsaid thoughts.",
    "main": "app.js",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "start": "node --env-file=.env.production dist/app.js",
        "dev": "nodemon",
        "test": "echo \"Error: no test specified\" && exit 1",
        "prepare": "husky"
    },
    "repository": {
        "type": "git",
        "url": "git@github.com-personal:adreno255/tell-me-something-backend.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "dependencies": {
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "http-status-codes": "^2.3.0",
        "mongoose": "^9.6.2",
        "morgan": "^1.10.1",
        "swagger-jsdoc": "^6.3.0",
        "swagger-ui-express": "^5.0.1",
        "winston": "^3.19.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@eslint/js": "^10.0.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.9.1",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.3",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "eslint --fix --max-warnings=0 --no-warn-ignored",
